{
  "name": "@starfoundrystudio/alphaclaw",
  "version": "0.9.18-starfoundry.12",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Setup UI, gateway manager, and onboarding wrapper for OpenClaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/starfoundrystudio/alphaclaw.git"
  },
  "bugs": {
    "url": "https://github.com/starfoundrystudio/alphaclaw/issues"
  },
  "homepage": "https://github.com/starfoundrystudio/alphaclaw#readme",
  "license": "MIT",
  "bin": {
    "alphaclaw": "bin/alphaclaw.js"
  },
  "files": [
    "bin/",
    "lib/"
  ],
  "scripts": {
    "start": "node bin/alphaclaw.js start",
    "build:ui": "node scripts/build-ui.mjs",
    "dev:ui": "node scripts/start-ui-sandbox.mjs --mode dashboard",
    "dev:ui:setup": "node scripts/start-ui-sandbox.mjs --mode setup",
    "dev:ui:persist": "node scripts/start-ui-sandbox.mjs --mode dashboard --persist",
    "dev:ui:build": "npm run build:ui && npm run dev:ui",
    "generate:openclaw-compatibility-manifest": "node scripts/generate-openclaw-compatibility-manifest.mjs",
    "generate:model-catalog-bootstrap": "node scripts/generate-model-catalog-bootstrap.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:watchdog": "vitest run tests/server/watchdog.test.js tests/server/watchdog-db.test.js tests/server/routes-watchdog.test.js",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run generate:openclaw-compatibility-manifest && npm run generate:model-catalog-bootstrap && npm run build:ui"
  },
  "dependencies": {
    "express": "^4.21.0",
    "http-proxy": "^1.18.1",
    "openclaw": "2026.6.10",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chart.js": "^4.5.1",
    "esbuild": "^0.25.9",
    "htm": "^3.1.1",
    "marked": "^16.4.1",
    "preact": "^10.27.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "vitest": "^4.0.18",
    "wouter-preact": "^3.7.1"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
