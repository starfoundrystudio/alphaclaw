{
  "schemaVersion": 1,
  "description": "AlphaClaw-owned setup catalog support policy. This declares the model access routes and providers AlphaClaw wants to present during onboarding; the generator validates managed plugin requirements against the pinned OpenClaw compatibility manifest and enriches models from provider-specific OpenClaw catalog probes.",
  "accessModes": {
    "subscription": {
      "label": "Subscription",
      "shortLabel": "Subscription",
      "description": "Use an existing provider subscription plan."
    },
    "provider-api": {
      "label": "Provider API Key",
      "shortLabel": "Provider API Key",
      "description": "Usage-based billing from the model provider directly."
    },
    "gateway": {
      "label": "AI gateway",
      "shortLabel": "Gateway",
      "description": "Usage-based billing across providers using a gateway."
    }
  },
  "providerProbes": [
    "anthropic",
    "byteplus",
    "byteplus-plan",
    "claude-cli",
    "cloudflare-ai-gateway",
    "cohere",
    "deepseek",
    "fireworks",
    "github-copilot",
    "kilocode",
    "mistral",
    "moonshot",
    "novita",
    "nvidia",
    "ollama-cloud",
    "openai",
    "openrouter",
    "tencent-tokenhub",
    "together",
    "venice",
    "vercel-ai-gateway",
    "volcengine",
    "volcengine-plan",
    "xiaomi",
    "zai"
  ],
  "providers": {
    "anthropic": {
      "label": "Anthropic",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["ANTHROPIC_API_KEY"],
      "recommendedModelKeys": ["anthropic/claude-opus-4-8", "anthropic/claude-sonnet-4-6"]
    },
    "byteplus": {
      "label": "BytePlus",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["BYTEPLUS_API_KEY"]
    },
    "byteplus-plan": {
      "label": "BytePlus Plan",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["BYTEPLUS_API_KEY"]
    },
    "claude-cli": {
      "label": "Claude CLI",
      "accessModes": ["subscription"],
      "authRoute": "claude-cli",
      "runtimeId": "claude-cli",
      "recommendedModelKeys": ["claude-cli/claude-opus-4-8", "claude-cli/claude-sonnet-4-6"]
    },
    "cloudflare-ai-gateway": {
      "label": "Cloudflare AI Gateway",
      "accessModes": ["gateway"],
      "authRoute": "api-key",
      "envKeys": ["CLOUDFLARE_AI_GATEWAY_API_KEY"],
      "requiredPlugins": ["cloudflare-ai-gateway"]
    },
    "cohere": {
      "label": "Cohere",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["COHERE_API_KEY"],
      "requiredPlugins": ["cohere"]
    },
    "deepseek": {
      "label": "DeepSeek",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["DEEPSEEK_API_KEY"],
      "requiredPlugins": ["deepseek"],
      "minimumProbeModelCount": 1
    },
    "fireworks": {
      "label": "Fireworks",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["FIREWORKS_API_KEY"],
      "requiredPlugins": ["fireworks"],
      "minimumProbeModelCount": 1
    },
    "github-copilot": {
      "label": "GitHub Copilot",
      "accessModes": [],
      "authRoute": "account-login",
      "hiddenFromOnboarding": true
    },
    "kilocode": {
      "label": "Kilo Gateway",
      "accessModes": ["gateway"],
      "authRoute": "api-key",
      "envKeys": ["KILOCODE_API_KEY"],
      "requiredPlugins": ["kilocode"]
    },
    "mistral": {
      "label": "Mistral",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["MISTRAL_API_KEY"]
    },
    "moonshot": {
      "label": "Moonshot",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["MOONSHOT_API_KEY"],
      "requiredPlugins": ["moonshot"],
      "minimumProbeModelCount": 1
    },
    "novita": {
      "label": "Novita",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["NOVITA_API_KEY"]
    },
    "nvidia": {
      "label": "NVIDIA",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["NVIDIA_API_KEY"]
    },
    "ollama-cloud": {
      "label": "Ollama Cloud",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["OLLAMA_API_KEY"]
    },
    "openai": {
      "label": "OpenAI",
      "accessModes": ["subscription", "provider-api"],
      "authRoutes": {
        "subscription": "codex-oauth",
        "provider-api": "api-key"
      },
      "runtimeIds": {
        "subscription": "codex"
      },
      "envKeys": ["OPENAI_API_KEY"],
      "requiredPluginsByAccessMode": {
        "subscription": ["codex"]
      },
      "allowedModelKeysByAccessMode": {
        "subscription": [
          "openai/gpt-5.5",
          "openai/gpt-5.6-sol",
          "openai/gpt-5.6-terra",
          "openai/gpt-5.6-luna"
        ],
        "provider-api": [
          "openai/gpt-5.5",
          "openai/gpt-5.6",
          "openai/gpt-5.6-sol",
          "openai/gpt-5.6-terra",
          "openai/gpt-5.6-luna"
        ]
      },
      "recommendedModelKeysByAccessMode": {
        "subscription": ["openai/gpt-5.6-sol"],
        "provider-api": ["openai/gpt-5.6"]
      },
      "minimumProbeModelCount": 5
    },
    "openrouter": {
      "label": "OpenRouter",
      "accessModes": ["gateway"],
      "authRoute": "api-key",
      "envKeys": ["OPENROUTER_API_KEY"],
      "publicModelCatalog": {
        "endpoint": "https://openrouter.ai/api/v1/models",
        "minimumModelCount": 100
      },
      "recommendedModelKeys": ["openrouter/openai/gpt-5.6-sol", "openrouter/anthropic/claude-sonnet-4.6"]
    },
    "tencent-tokenhub": {
      "label": "Tencent TokenHub",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["TENCENT_TOKENHUB_API_KEY"],
      "requiredPlugins": ["tencent"],
      "minimumProbeModelCount": 1
    },
    "together": {
      "label": "Together",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["TOGETHER_API_KEY"]
    },
    "venice": {
      "label": "Venice",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["VENICE_API_KEY"],
      "requiredPlugins": ["venice"],
      "minimumProbeModelCount": 1
    },
    "vercel-ai-gateway": {
      "label": "Vercel AI Gateway",
      "accessModes": ["gateway"],
      "authRoute": "api-key",
      "envKeys": ["AI_GATEWAY_API_KEY"],
      "requiredPlugins": ["vercel-ai-gateway"],
      "publicModelCatalog": {
        "endpoint": "https://ai-gateway.vercel.sh/v1/models",
        "modelTypes": ["language"],
        "minimumModelCount": 100
      },
      "recommendedModelKeys": [
        "vercel-ai-gateway/anthropic/claude-opus-4.8",
        "vercel-ai-gateway/anthropic/claude-sonnet-4.6",
        "vercel-ai-gateway/openai/gpt-5.6-sol"
      ]
    },
    "volcengine": {
      "label": "Volcano Engine",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["VOLCANO_ENGINE_API_KEY"]
    },
    "volcengine-plan": {
      "label": "Volcano Engine Plan",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["VOLCANO_ENGINE_API_KEY"]
    },
    "xiaomi": {
      "label": "Xiaomi",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["XIAOMI_API_KEY"]
    },
    "zai": {
      "label": "Z.AI",
      "accessModes": ["provider-api"],
      "authRoute": "api-key",
      "envKeys": ["ZAI_API_KEY"],
      "requiredPlugins": ["zai"],
      "minimumProbeModelCount": 1
    }
  },
  "explicitModels": [
    {
      "key": "openai/gpt-5.5",
      "provider": "openai",
      "label": "GPT-5.5",
      "accessModes": ["subscription", "provider-api"]
    },
    {
      "key": "openrouter/openai/gpt-5.5",
      "provider": "openrouter",
      "label": "GPT-5.5",
      "accessModes": ["gateway"],
      "accessLabel": "via OpenRouter"
    },
    {
      "key": "openrouter/anthropic/claude-sonnet-4.6",
      "provider": "openrouter",
      "label": "Claude Sonnet 4.6",
      "accessModes": ["gateway"],
      "accessLabel": "via OpenRouter",
      "recommendation": "recommended"
    },
    {
