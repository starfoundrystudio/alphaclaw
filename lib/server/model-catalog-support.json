      "accessModes": ["gateway"],
      "accessLabel": "via Vercel AI Gateway",
      "recommendation": "recommended"
    },
    {
      "key": "vercel-ai-gateway/anthropic/claude-opus-4.8",
      "provider": "vercel-ai-gateway",
      "label": "Claude Opus 4.8",
      "accessModes": ["gateway"],
      "accessLabel": "via Vercel AI Gateway",
      "recommendation": "recommended"
    },
    {
      "key": "kilocode/openai/gpt-5.5",
      "provider": "kilocode",
      "label": "GPT-5.5",
      "accessModes": ["gateway"],
      "accessLabel": "via Kilo Gateway"
    },
    {
      "key": "cloudflare-ai-gateway/openai/gpt-5.5",
      "provider": "cloudflare-ai-gateway",
      "label": "GPT-5.5",
      "accessModes": ["gateway"],
      "accessLabel": "via Cloudflare AI Gateway"
    }
  ]
}
